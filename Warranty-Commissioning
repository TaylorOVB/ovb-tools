<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="OVB Tools" />
  <meta name="theme-color" content="#141210" />
  <link rel="icon" type="image/png" href="https://cdn.prod.website-files.com/680c4e282fbc1c583a3a7cc2/69a4a9e940d2f6303215cd3e_OVBear%20(1).png" />
  <link rel="apple-touch-icon" href="https://cdn.prod.website-files.com/680c4e282fbc1c583a3a7cc2/69a4a9e940d2f6303215cd3e_OVBear%20(1).png" />
  <title>Warranty & Commissioning — OVB</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #141210; --surface: #1A1816; --card: #222020; --card2: #2A2826;
      --tan: #C7AA8B; --tan-d: rgba(199,170,139,0.08); --tan-m: rgba(199,170,139,0.18);
      --border: rgba(199,170,139,0.09); --border2: rgba(199,170,139,0.22);
      --smoke: #F2EFE8; --muted: rgba(242,239,232,0.38); --muted2: rgba(242,239,232,0.18);
      --warn: #D4714A; --green: #4CAF84;
      --mono: 'DM Mono', monospace; --sans: 'DM Sans', sans-serif; --r: 4px;
    }

    body { background: var(--bg); font-family: var(--sans); color: var(--smoke); -webkit-font-smoothing: antialiased; min-height: 100vh; }

    input, select, textarea {
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--r);
      color: var(--smoke); font-family: var(--sans); font-size: 13px; padding: 8px 10px;
      outline: none; width: 100%; transition: border-color 0.12s;
    }
    input:focus, select:focus, textarea:focus { border-color: var(--border2); }
    input[type="date"] { color-scheme: dark; }
    select { appearance: none; -webkit-appearance: none; cursor: pointer; }
    textarea { resize: vertical; }
    input::placeholder, textarea::placeholder { color: var(--muted2); }

    .screen-only { }
    .print-only { display: none !important; }

    @media print {
      body { background: white !important; color: black !important; font-family: 'DM Sans', sans-serif !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .screen-only { display: none !important; }
      .print-only { display: block !important; }
      @page { margin: 0.65in; size: letter; }
    }
  </style>
</head>
<body>
<div id="root"></div>

<script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<script type="text/babel">
const { useState } = React;

const PROJECT_TYPES = ['New Construction', 'Addition', 'Remodel', 'ADU'];

const SYSTEMS = [
  { id: 'hvac',       label: 'HVAC & Mechanical',        hint: 'Thermostat setpoints, filter size/location, all zones tested, fresh air damper set' },
  { id: 'plumbing',   label: 'Plumbing',                  hint: 'Water pressure tested, all fixtures run, water heater temp & TPR valve, shutoffs tagged' },
  { id: 'electrical', label: 'Electrical',                hint: 'Panel schedule labeled & photo\'d, GFCI/AFCI tested, smoke & CO detectors verified' },
  { id: 'roofing',    label: 'Roofing & Waterproofing',   hint: 'All flashing inspected, penetrations sealed, gutters & downspouts clear' },
  { id: 'windows',    label: 'Windows & Exterior Doors',  hint: 'Operation, locks, weatherstripping, screens installed, hardware verified' },
  { id: 'insulation', label: 'Insulation & Air Sealing',  hint: 'R-values per plan confirmed, penetrations sealed, blower door result if performed' },
  { id: 'finishes',   label: 'Interior Finishes',         hint: 'Touch-ups complete, all hardware installed, punch list items closed & signed off' },
  { id: 'site',       label: 'Site & Drainage',           hint: 'Final grade verified slopes away from foundation, disturbed areas restored' },
  { id: 'appliances', label: 'Appliances',                hint: 'All units tested, manufacturer warranties registered & transferred to owner' },
];

/* ── Shared helpers ── */
const fmt = (d) => {
  if (!d) return '_______________';
  const dt = new Date(d + 'T00:00:00');
  return dt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
};
const warrantyEnd = (completionDate) => {
  if (!completionDate) return '_______________';
  const d = new Date(completionDate + 'T00:00:00');
  d.setFullYear(d.getFullYear() + 3);
  return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
};
const yr = (d) => d ? new Date(d + 'T00:00:00').getFullYear() : new Date().getFullYear();

/* ── Form primitives ── */
function Label({ children }) {
  return <div style={{ fontFamily: 'DM Mono, monospace', fontSize: 8, letterSpacing: '0.12em', textTransform: 'uppercase', color: 'rgba(199,170,139,0.45)', marginBottom: 4 }}>{children}</div>;
}
function Field({ label, children, style }) {
  return <div style={{ display: 'flex', flexDirection: 'column', ...style }}><Label>{label}</Label>{children}</div>;
}
function Input({ value, onChange, placeholder, type='text' }) {
  return <input type={type} value={value} onChange={e => onChange(e.target.value)} placeholder={placeholder} />;
}
function Textarea({ value, onChange, placeholder, rows=3 }) {
  return <textarea value={value} onChange={e => onChange(e.target.value)} placeholder={placeholder} rows={rows} />;
}
function Select({ value, onChange, options, placeholder }) {
  return (
    <div style={{ position: 'relative' }}>
      <select value={value} onChange={e => onChange(e.target.value)} style={{ color: value ? '#F2EFE8' : 'rgba(242,239,232,0.25)' }}>
        <option value="" disabled>{placeholder}</option>
        {options.map(o => <option key={o} value={o}>{o}</option>)}
      </select>
      <svg style={{ position: 'absolute', right: 10, top: '50%', transform: 'translateY(-50%)', pointerEvents: 'none', stroke: 'rgba(199,170,139,0.4)' }} width="10" height="10" viewBox="0 0 24 24" fill="none" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
    </div>
  );
}
function SecHdr({ n, title }) {
  return (
    <div style={{ display: 'flex', alignItems: 'center', gap: 10, marginBottom: 12 }}>
      <div style={{ background: '#1E1C1A', color: '#C7AA8B', fontFamily: 'DM Mono, monospace', fontSize: 9, fontWeight: 500, padding: '2px 8px', borderRadius: 4, flexShrink: 0 }}>{n}</div>
      <div style={{ fontFamily: 'DM Mono, monospace', fontSize: 8, letterSpacing: '0.14em', textTransform: 'uppercase', color: 'rgba(199,170,139,0.35)' }}>{title}</div>
      <div style={{ flex: 1, height: 1, background: 'rgba(199,170,139,0.09)' }} />
    </div>
  );
}

/* ── Print: Warranty Certificate ── */
function WarrantyDoc({ firstName, lastName, address, city, projectType, jobNum, contractDate, completionDate, scope, warrantyNotes }) {
  const clientName = [firstName, lastName].filter(Boolean).join(' ') || '_______________';
  const fullAddress = [address, city, 'UT'].filter(Boolean).join(', ') || '_______________';
  const s = { fontFamily: 'DM Sans, sans-serif', color: '#1a1a1a' };
  const mono = 'DM Mono, monospace';
  const tan = '#B8966E';
  const rule = { height: 1, background: '#ddd', margin: '0 0 20px' };
  const lbl = { fontSize: 8, fontFamily: mono, letterSpacing: '0.12em', textTransform: 'uppercase', color: '#999', display: 'block', marginBottom: 3 };

  return (
    <div style={{ ...s, padding: 0, lineHeight: 1 }}>

      {/* Header */}
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: 24, paddingBottom: 18, borderBottom: '2.5px solid #1E1C1A' }}>
        <div>
          <div style={{ fontSize: 20, fontWeight: 700, color: '#1E1C1A', marginBottom: 5 }}>Ogden Valley Builders</div>
          <div style={{ fontSize: 11, color: '#555', lineHeight: 1.7 }}>
            info@ogdenvalleybuilders.com &nbsp;·&nbsp; (385) 288-7921<br />
            Weber &amp; Morgan County, UT &nbsp;·&nbsp; GC #14219939-5501
          </div>
        </div>
        <div style={{ textAlign: 'right', fontFamily: mono }}>
          <div style={{ fontSize: 10, color: '#aaa', marginBottom: 3 }}>JOB #{jobNum || '___________'}</div>
          <div style={{ fontSize: 10, color: '#aaa' }}>Issued {fmt(completionDate)}</div>
        </div>
      </div>

      {/* Title */}
      <div style={{ textAlign: 'center', marginBottom: 24 }}>
        <div style={{ fontSize: 9, fontFamily: mono, letterSpacing: '0.22em', textTransform: 'uppercase', color: tan, marginBottom: 6 }}>Limited Warranty Certificate</div>
        <div style={{ fontSize: 22, fontWeight: 700, color: '#1E1C1A' }}>36-Month Workmanship Warranty</div>
      </div>

      {/* Project Info Box */}
      <div style={{ border: '1px solid #d5d0c8', borderRadius: 4, padding: '14px 18px', marginBottom: 22, display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '12px 24px', background: '#faf9f7' }}>
        <div><span style={lbl}>Owner</span><div style={{ fontSize: 14, fontWeight: 600 }}>{clientName}</div></div>
        <div><span style={lbl}>Project Type</span><div style={{ fontSize: 14, fontWeight: 600 }}>{projectType || '_______________'}</div></div>
        <div style={{ gridColumn: '1 / -1' }}><span style={lbl}>Property Address</span><div style={{ fontSize: 14, fontWeight: 600 }}>{fullAddress}</div></div>
        <div><span style={lbl}>Contract Date</span><div style={{ fontSize: 13, fontWeight: 500 }}>{fmt(contractDate)}</div></div>
        <div><span style={lbl}>Substantial Completion</span><div style={{ fontSize: 13, fontWeight: 500 }}>{fmt(completionDate)}</div></div>
        <div style={{ gridColumn: '1 / -1', paddingTop: 10, borderTop: '1px solid #e5e0d8', marginTop: 2 }}>
          <span style={lbl}>Warranty Expires</span>
          <div style={{ fontSize: 15, fontWeight: 700, color: tan }}>{warrantyEnd(completionDate)}</div>
        </div>
      </div>

      {/* Work Performed */}
      {scope && (
        <div style={{ marginBottom: 18 }}>
          <div style={{ fontSize: 9, fontFamily: mono, letterSpacing: '0.14em', textTransform: 'uppercase', color: '#888', marginBottom: 6 }}>Work Performed</div>
          <div style={{ fontSize: 12.5, lineHeight: 1.7, color: '#333' }}>{scope}</div>
        </div>
      )}

      {/* Coverage */}
      <div style={{ marginBottom: 16 }}>
        <div style={{ fontSize: 9, fontFamily: mono, letterSpacing: '0.14em', textTransform: 'uppercase', color: '#888', marginBottom: 6 }}>Warranty Coverage</div>
        <div style={{ fontSize: 12, lineHeight: 1.75, color: '#333' }}>
          Ogden Valley Builders (&ldquo;Contractor&rdquo;) warrants all labor and materials furnished by Contractor on the above-referenced project against defects in workmanship for a period of <strong>thirty-six (36) months</strong> from the date of substantial completion. This warranty is provided in addition to, and does not limit, any applicable statutory warranties under Utah law, including the Utah Right to Repair Act.
        </div>
      </div>

      {/* Exclusions */}
      <div style={{ marginBottom: 16 }}>
        <div style={{ fontSize: 9, fontFamily: mono, letterSpacing: '0.14em', textTransform: 'uppercase', color: '#888', marginBottom: 6 }}>Exclusions</div>
        <div style={{ fontSize: 11.5, lineHeight: 1.75, color: '#555' }}>
          This warranty does not cover: (a) damage resulting from owner modifications, misuse, or neglect after substantial completion; (b) normal wear, settling, and deterioration; (c) damage caused by acts of nature including flooding, earthquake, or severe weather; (d) appliances and manufactured equipment covered under separate manufacturer warranties; (e) defects arising from owner-supplied materials; or (f) damage resulting from failure to perform routine maintenance.
        </div>
      </div>

      {/* Additional Notes */}
      {warrantyNotes && (
        <div style={{ marginBottom: 16 }}>
          <div style={{ fontSize: 9, fontFamily: mono, letterSpacing: '0.14em', textTransform: 'uppercase', color: '#888', marginBottom: 6 }}>Additional Warranty Terms</div>
          <div style={{ fontSize: 12, lineHeight: 1.75, color: '#333' }}>{warrantyNotes}</div>
        </div>
      )}

      {/* Claim Procedure */}
      <div style={{ marginBottom: 16 }}>
        <div style={{ fontSize: 9, fontFamily: mono, letterSpacing: '0.14em', textTransform: 'uppercase', color: '#888', marginBottom: 6 }}>Warranty Claim Procedure</div>
        <div style={{ fontSize: 11.5, lineHeight: 1.75, color: '#555' }}>
          To submit a warranty claim, contact Ogden Valley Builders at <strong>(385) 288-7921</strong> or <strong>info@ogdenvalleybuilders.com</strong>. Contractor will acknowledge receipt within two (2) business days and schedule an inspection within ten (10) business days of acknowledgment. Defects covered under this warranty will be remedied at no cost to the owner.
        </div>
      </div>

      {/* Transferability */}
      <div style={{ marginBottom: 22, padding: '11px 14px', background: '#f5f2ed', borderRadius: 4, border: '1px solid #e0dbd4' }}>
        <div style={{ fontSize: 12, lineHeight: 1.65, color: '#444' }}>
          <strong>Transferability:</strong> This warranty is transferable to subsequent owners of the above-referenced property during the warranty period. Transfer does not extend or reset the warranty period. Contractor should be notified of any transfer of ownership in writing.
        </div>
      </div>

      {/* Signatures */}
      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 48, paddingTop: 20, borderTop: '1px solid #ddd' }}>
        <div>
          <div style={{ height: 36 }} />
          <div style={{ height: 1, background: '#999', marginBottom: 7 }} />
          <div style={{ fontSize: 11, color: '#555', fontFamily: mono }}>Taylor Whitesides — Ogden Valley Builders</div>
          <div style={{ fontSize: 10, color: '#aaa', fontFamily: mono, marginTop: 3 }}>Date: _______________</div>
        </div>
        <div>
          <div style={{ height: 36 }} />
          <div style={{ height: 1, background: '#999', marginBottom: 7 }} />
          <div style={{ fontSize: 11, color: '#555', fontFamily: mono }}>{clientName} — Owner</div>
          <div style={{ fontSize: 10, color: '#aaa', fontFamily: mono, marginTop: 3 }}>Date: _______________</div>
        </div>
      </div>

    </div>
  );
}

/* ── Print: Commissioning Record ── */
function CommissioningDoc({ firstName, lastName, address, city, projectType, jobNum, completionDate, scope, systems }) {
  const clientName = [firstName, lastName].filter(Boolean).join(' ') || '_______________';
  const lastName2 = lastName || '[Client]';
  const fullAddress = [address, city, 'UT'].filter(Boolean).join(', ') || '_______________';
  const commissioned = SYSTEMS.filter(s => systems[s.id] && systems[s.id].checked);
  const mono = 'DM Mono, monospace';
  const lbl = { fontSize: 8, fontFamily: mono, letterSpacing: '0.1em', textTransform: 'uppercase', color: '#888', display: 'block', marginBottom: 3 };

  return (
    <div style={{ fontFamily: 'DM Sans, sans-serif', color: '#1a1a1a', lineHeight: 1 }}>

      {/* Header */}
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: 22, paddingBottom: 16, borderBottom: '2.5px solid #1E1C1A' }}>
        <div>
          <div style={{ fontSize: 9, fontFamily: mono, letterSpacing: '0.2em', textTransform: 'uppercase', color: '#B8966E', marginBottom: 5 }}>Internal — Filed Copy</div>
          <div style={{ fontSize: 20, fontWeight: 700, color: '#1E1C1A' }}>Project Commissioning Record</div>
          <div style={{ fontSize: 11, color: '#666', marginTop: 4 }}>Ogden Valley Builders &nbsp;·&nbsp; GC #14219939-5501</div>
        </div>
        <div style={{ textAlign: 'right', fontFamily: mono, fontSize: 10, color: '#999', lineHeight: 1.9 }}>
          <div>Job #{jobNum || '___________'}</div>
          <div>Completed: {fmt(completionDate)}</div>
          <div>Warranty Exp: {warrantyEnd(completionDate)}</div>
        </div>
      </div>

      {/* Project Info */}
      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr 1fr', gap: '10px 20px', marginBottom: 22, padding: '13px 16px', background: '#f5f2ed', borderRadius: 4 }}>
        <div><span style={lbl}>Owner</span><div style={{ fontSize: 13, fontWeight: 600 }}>{clientName}</div></div>
        <div><span style={lbl}>Project Type</span><div style={{ fontSize: 13, fontWeight: 600 }}>{projectType || '—'}</div></div>
        <div><span style={lbl}>Completion Date</span><div style={{ fontSize: 13, fontWeight: 600 }}>{fmt(completionDate)}</div></div>
        <div style={{ gridColumn: '1 / -1' }}><span style={lbl}>Property Address</span><div style={{ fontSize: 13, fontWeight: 600 }}>{fullAddress}</div></div>
        {scope && <div style={{ gridColumn: '1 / -1' }}><span style={lbl}>Scope Summary</span><div style={{ fontSize: 12, lineHeight: 1.6, color: '#444' }}>{scope}</div></div>}
      </div>

      {/* Systems */}
      <div style={{ marginBottom: 22 }}>
        <div style={{ fontSize: 9, fontFamily: mono, letterSpacing: '0.14em', textTransform: 'uppercase', color: '#888', marginBottom: 12 }}>Systems Commissioned &amp; Verified</div>

        {commissioned.length === 0 && (
          <div style={{ fontSize: 12, color: '#aaa', fontStyle: 'italic' }}>No systems selected in this record.</div>
        )}

        {commissioned.map((sys, i) => (
          <div key={sys.id} style={{ display: 'flex', gap: 12, paddingBottom: 11, marginBottom: 11, borderBottom: i < commissioned.length - 1 ? '1px solid #eee' : 'none', alignItems: 'flex-start' }}>
            <div style={{ width: 14, height: 14, borderRadius: 2, background: '#1E1C1A', display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0, marginTop: 1 }}>
              <svg width="9" height="9" viewBox="0 0 9 9" fill="none"><polyline points="1.5,4.5 3.5,6.5 7.5,2" stroke="white" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/></svg>
            </div>
            <div style={{ flex: 1 }}>
              <div style={{ fontSize: 13, fontWeight: 600, marginBottom: systems[sys.id].notes ? 3 : 0 }}>{sys.label}</div>
              {systems[sys.id].notes && <div style={{ fontSize: 11.5, color: '#555', lineHeight: 1.65 }}>{systems[sys.id].notes}</div>}
              {!systems[sys.id].notes && <div style={{ fontSize: 11, color: '#bbb', fontStyle: 'italic' }}>No notes recorded.</div>}
            </div>
          </div>
        ))}
      </div>

      {/* Filing instruction */}
      <div style={{ padding: '10px 14px', background: '#f0ede8', borderRadius: 4, marginBottom: 22, fontSize: 10, color: '#666', fontFamily: mono, lineHeight: 1.7, borderLeft: '3px solid #B8966E' }}>
        <div style={{ fontSize: 8, letterSpacing: '0.1em', textTransform: 'uppercase', color: '#B8966E', marginBottom: 3 }}>File This Document</div>
        Google Drive → [Job Folder] → Closeout → {lastName2} – Commissioning Record – {yr(completionDate)}.pdf
      </div>

      {/* Sign-off */}
      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr 1fr', gap: 32, paddingTop: 18, borderTop: '1px solid #ddd' }}>
        <div>
          <div style={{ fontSize: 9, fontFamily: mono, letterSpacing: '0.1em', textTransform: 'uppercase', color: '#999', marginBottom: 22 }}>Commissioned By</div>
          <div style={{ height: 1, background: '#999', marginBottom: 6 }} />
          <div style={{ fontSize: 10, color: '#666', fontFamily: mono }}>Name / Signature</div>
        </div>
        <div>
          <div style={{ fontSize: 9, fontFamily: mono, letterSpacing: '0.1em', textTransform: 'uppercase', color: '#999', marginBottom: 22 }}>Date Commissioned</div>
          <div style={{ height: 1, background: '#999', marginBottom: 6 }} />
          <div style={{ fontSize: 10, color: '#666', fontFamily: mono }}>{fmt(completionDate)}</div>
        </div>
        <div>
          <div style={{ fontSize: 9, fontFamily: mono, letterSpacing: '0.1em', textTransform: 'uppercase', color: '#999', marginBottom: 22 }}>Client Walkthrough</div>
          <div style={{ height: 1, background: '#999', marginBottom: 6 }} />
          <div style={{ fontSize: 10, color: '#aaa', fontFamily: mono }}>Date: ___________</div>
        </div>
      </div>

    </div>
  );
}

/* ── Main App ── */
function App() {
  const [firstName,      setFirstName]      = useState('');
  const [lastName,       setLastName]       = useState('');
  const [address,        setAddress]        = useState('');
  const [city,           setCity]           = useState('');
  const [projectType,    setProjectType]    = useState('');
  const [jobNum,         setJobNum]         = useState('');
  const [contractDate,   setContractDate]   = useState('');
  const [completionDate, setCompletionDate] = useState('');
  const [scope,          setScope]          = useState('');
  const [warrantyNotes,  setWarrantyNotes]  = useState('');
  const [printMode,      setPrintMode]      = useState(null);

  const [systems, setSystems] = useState(
    Object.fromEntries(SYSTEMS.map(s => [s.id, { checked: false, notes: '' }]))
  );

  const toggleSystem = (id) => setSystems(p => ({ ...p, [id]: { ...p[id], checked: !p[id].checked } }));
  const setSystemNotes = (id, v) => setSystems(p => ({ ...p, [id]: { ...p[id], notes: v } }));

  const handlePrint = (mode) => {
    setPrintMode(mode);
    setTimeout(() => { window.print(); setTimeout(() => setPrintMode(null), 600); }, 220);
  };

  const handleReset = () => {
    if (!window.confirm('Reset all fields? This cannot be undone.')) return;
    setFirstName(''); setLastName(''); setAddress(''); setCity('');
    setProjectType(''); setJobNum(''); setContractDate(''); setCompletionDate('');
    setScope(''); setWarrantyNotes('');
    setSystems(Object.fromEntries(SYSTEMS.map(s => [s.id, { checked: false, notes: '' }])));
    setPrintMode(null);
  };

  const docProps = { firstName, lastName, address, city, projectType, jobNum, contractDate, completionDate, scope, warrantyNotes, systems };
  const commissioning = SYSTEMS.filter(s => systems[s.id].checked).length;

  /* ── Colors ── */
  const c = { bg: '#141210', surface: '#1A1816', card: '#222020', card2: '#2A2826', tan: '#C7AA8B', smoke: '#F2EFE8', border: 'rgba(199,170,139,0.09)', border2: 'rgba(199,170,139,0.22)', muted: 'rgba(242,239,232,0.38)', muted2: 'rgba(242,239,232,0.18)' };

  return (
    <div>

      {/* ── SCREEN UI ── */}
      <div className="screen-only">

        {/* Topbar */}
        <div style={{ background: c.surface, borderBottom: `1px solid ${c.border}`, padding: '11px 20px', display: 'flex', alignItems: 'center', gap: 10, position: 'sticky', top: 0, zIndex: 10 }}>
          <a href="/" style={{ color: 'rgba(199,170,139,0.4)', textDecoration: 'none', fontFamily: 'DM Mono, monospace', fontSize: 9 }}>← OVB Tools</a>
          <div style={{ width: 1, height: 12, background: c.border2 }} />
          <span style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, fontWeight: 500, letterSpacing: '0.14em', textTransform: 'uppercase', color: c.tan }}>Warranty &amp; Commissioning</span>
          <div style={{ marginLeft: 'auto', fontFamily: 'DM Mono, monospace', fontSize: 8, color: c.muted2 }}>GC #14219939-5501</div>
        </div>

        {/* Form */}
        <div style={{ maxWidth: 680, margin: '0 auto', padding: '20px 16px 100px' }}>

          {/* 01 — Project Details */}
          <div style={{ marginBottom: 28 }}>
            <SecHdr n="01" title="Project Details" />
            <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 10 }}>
              <Field label="Client First Name"><Input value={firstName} onChange={setFirstName} placeholder="First" /></Field>
              <Field label="Client Last Name"><Input value={lastName} onChange={setLastName} placeholder="Last" /></Field>
              <Field label="Property Address" style={{ gridColumn: '1 / -1' }}><Input value={address} onChange={setAddress} placeholder="123 Main Street" /></Field>
              <Field label="City"><Input value={city} onChange={setCity} placeholder="Ogden" /></Field>
              <Field label="Project Type"><Select value={projectType} onChange={setProjectType} options={PROJECT_TYPES} placeholder="Select type" /></Field>
              <Field label="OVB Job #"><Input value={jobNum} onChange={setJobNum} placeholder="OVB-2026-001" /></Field>
              <Field label="Contract Date"><Input type="date" value={contractDate} onChange={setContractDate} /></Field>
              <Field label="Substantial Completion Date"><Input type="date" value={completionDate} onChange={setCompletionDate} /></Field>
            </div>
            {completionDate && (
              <div style={{ marginTop: 10, padding: '8px 12px', background: c.surface, borderRadius: 4, border: `1px solid ${c.border}`, fontFamily: 'DM Mono, monospace', fontSize: 9, color: c.tan }}>
                Warranty expires: <strong>{warrantyEnd(completionDate)}</strong>
              </div>
            )}
          </div>

          {/* 02 — Scope */}
          <div style={{ marginBottom: 28 }}>
            <SecHdr n="02" title="Scope of Work Performed" />
            <Textarea value={scope} onChange={setScope} placeholder="Describe the completed work — e.g. 'Construction of a 400 SF primary bedroom addition including structural, mechanical, electrical, plumbing, insulation, drywall, paint, flooring, and trim to match existing.'" rows={4} />
          </div>

          {/* 03 — Systems */}
          <div style={{ marginBottom: 28 }}>
            <SecHdr n="03" title={`Systems Commissioned${commissioning > 0 ? ` · ${commissioning} selected` : ''}`} />
            <div style={{ display: 'flex', flexDirection: 'column', gap: 4 }}>
              {SYSTEMS.map(sys => (
                <div key={sys.id} style={{ background: c.card, border: `1px solid ${systems[sys.id].checked ? c.border2 : c.border}`, borderRadius: 4, overflow: 'hidden', transition: 'border-color 0.12s' }}>
                  <div onClick={() => toggleSystem(sys.id)} style={{ display: 'flex', alignItems: 'center', gap: 10, padding: '10px 12px', cursor: 'pointer', userSelect: 'none' }}>
                    <div style={{ width: 15, height: 15, borderRadius: 2, border: `1.5px solid ${systems[sys.id].checked ? c.tan : 'rgba(199,170,139,0.28)'}`, background: systems[sys.id].checked ? c.tan : 'transparent', display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0, transition: 'all 0.12s' }}>
                      {systems[sys.id].checked && <svg width="9" height="9" viewBox="0 0 9 9" fill="none"><polyline points="1.5,4.5 3.5,6.5 7.5,2" stroke="#141210" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round"/></svg>}
                    </div>
                    <span style={{ fontSize: 13, fontWeight: 500, flex: 1, color: c.smoke }}>{sys.label}</span>
                    <span style={{ fontFamily: 'DM Mono, monospace', fontSize: 7.5, color: systems[sys.id].checked ? 'rgba(199,170,139,0.5)' : c.muted2 }}>{systems[sys.id].checked ? 'commissioned' : 'not included'}</span>
                  </div>
                  {systems[sys.id].checked && (
                    <div style={{ padding: '0 12px 10px 37px' }}>
                      <textarea
                        value={systems[sys.id].notes}
                        onChange={e => setSystemNotes(sys.id, e.target.value)}
                        placeholder={sys.hint}
                        rows={2}
                        style={{ background: '#1A1816', border: '1px solid rgba(199,170,139,0.12)', borderRadius: 4, color: '#F2EFE8', fontFamily: 'DM Sans, sans-serif', fontSize: 12, padding: '7px 10px', outline: 'none', width: '100%', resize: 'vertical', transition: 'border-color 0.12s' }}
                      />
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>

          {/* 04 — Additional Warranty Notes */}
          <div style={{ marginBottom: 28 }}>
            <SecHdr n="04" title="Additional Warranty Notes" />
            <Textarea value={warrantyNotes} onChange={setWarrantyNotes} placeholder="Any specific warranty carve-outs, special conditions, or items to note on the certificate (optional)..." rows={3} />
          </div>

          {/* File tip */}
          <div style={{ padding: '10px 14px', background: c.surface, borderRadius: 4, border: `1px solid ${c.border}`, fontFamily: 'DM Mono, monospace', fontSize: 8, color: c.muted2, lineHeight: 1.7 }}>
            <span style={{ color: 'rgba(199,170,139,0.5)', letterSpacing: '0.1em', textTransform: 'uppercase' }}>After printing:</span> save both PDFs to Google Drive → [Job Folder] → Closeout. Warranty goes to client at walkthrough. Commissioning record stays on file.
          </div>

        </div>

        {/* Sticky bottom bar */}
        <div style={{ position: 'fixed', bottom: 0, left: 0, right: 0, background: c.surface, borderTop: `1px solid ${c.border}`, padding: '10px 16px 10px', display: 'flex', gap: 8, alignItems: 'center' }}>
          <button onClick={() => handlePrint('warranty')} style={{ padding: '9px 16px', background: c.tan, color: '#141210', border: 'none', borderRadius: 4, fontFamily: 'DM Mono, monospace', fontSize: 9, fontWeight: 600, letterSpacing: '0.08em', textTransform: 'uppercase', cursor: 'pointer' }}>
            Print Warranty Certificate
          </button>
          <button onClick={() => handlePrint('commissioning')} style={{ padding: '9px 16px', background: 'transparent', color: c.tan, border: `1px solid rgba(199,170,139,0.3)`, borderRadius: 4, fontFamily: 'DM Mono, monospace', fontSize: 9, letterSpacing: '0.08em', textTransform: 'uppercase', cursor: 'pointer' }}>
            Print Commissioning Record
          </button>
          <div style={{ flex: 1 }} />
          <button onClick={handleReset} style={{ padding: '9px 14px', background: 'transparent', color: c.muted2, border: `1px solid rgba(242,239,232,0.08)`, borderRadius: 4, fontFamily: 'DM Mono, monospace', fontSize: 9, letterSpacing: '0.06em', textTransform: 'uppercase', cursor: 'pointer' }}>
            Reset
          </button>
        </div>

      </div>

      {/* ── PRINT DOCUMENTS ── */}
      {printMode === 'warranty' && (
        <div className="print-only">
          <WarrantyDoc {...docProps} />
        </div>
      )}

      {printMode === 'commissioning' && (
        <div className="print-only">
          <CommissioningDoc {...docProps} />
        </div>
      )}

    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
</script>
</body>
</html>
